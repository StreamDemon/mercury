# AWS ECS Fargate deployment environment
# Copy to .env.aws and fill in values before deploying
#
# Secrets (DATABASE_URL, BETTER_AUTH_SECRET, ANTHROPIC_API_KEY, OPENAI_API_KEY,
# GITHUB_TOKEN) are injected via AWS Secrets Manager — do NOT set them here.

# Deployment mode
MERCURY_DEPLOYMENT_MODE=authenticated
MERCURY_DEPLOYMENT_EXPOSURE=public
MERCURY_PUBLIC_URL=https://mercury.example.com

# Server
HOST=0.0.0.0
PORT=3100
NODE_ENV=production
SERVE_UI=true

# Mercury paths
MERCURY_HOME=/mercury
MERCURY_INSTANCE_ID=default
MERCURY_CONFIG=/mercury/instances/default/config.json

# Auto-apply migrations on startup
MERCURY_MIGRATION_AUTO_APPLY=true

# Enable heartbeat scheduler for remote agents
HEARTBEAT_SCHEDULER_ENABLED=true

# Post-deploy hardening (uncomment after first user signs up)
# MERCURY_AUTH_DISABLE_SIGN_UP=true
